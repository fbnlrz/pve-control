{
  "triggers": [
    {
      "id": "lxc_started",
      "title": { "en": "Started", "de": "Gestartet" }
    },
    {
      "id": "lxc_stopped",
      "title": { "en": "Stopped", "de": "Gestoppt" }
    },
    {
      "id": "lxc_status_changed",
      "title": { "en": "Status changed", "de": "Status geändert" },
      "tokens": [
        {
          "name": "status",
          "type": "string",
          "title": { "en": "Status", "de": "Status" },
          "example": "running"
        }
      ]
    }
  ],
  "conditions": [
    {
      "id": "lxc_is_running",
      "title": { "en": "Is running", "de": "Läuft" },
      "titleFormatted": { "en": "!{{Is|Isn't}} running", "de": "!{{Läuft|Läuft nicht}}" }
    }
  ],
  "actions": [
    { "id": "lxc_start", "title": { "en": "Start", "de": "Starten" } },
    {
      "id": "lxc_shutdown",
      "title": { "en": "Shut down", "de": "Herunterfahren" },
      "hint": { "en": "Sends a graceful shutdown request.", "de": "Sendet eine reguläre Herunterfahren-Anfrage." }
    },
    {
      "id": "lxc_stop",
      "title": { "en": "Stop", "de": "Stoppen" },
      "hint": { "en": "Immediately stops the container; unsaved data may be lost.", "de": "Stoppt den Container sofort; ungespeicherte Daten können verloren gehen." }
    },
    { "id": "lxc_reboot", "title": { "en": "Reboot", "de": "Neustarten" } },
    { "id": "lxc_suspend", "title": { "en": "Suspend", "de": "Pausieren" } },
    { "id": "lxc_resume", "title": { "en": "Resume", "de": "Fortsetzen" } },
    {
      "id": "lxc_create_snapshot",
      "title": { "en": "Create snapshot", "de": "Snapshot erstellen" },
      "titleFormatted": {
        "en": "Create snapshot [[name]] with description [[description]]",
        "de": "Snapshot [[name]] mit Beschreibung [[description]] erstellen"
      },
      "args": [
        { "name": "name", "type": "text", "placeholder": { "en": "snapshot name", "de": "Snapshot-Name" } },
        { "name": "description", "type": "text", "required": false, "placeholder": { "en": "description", "de": "Beschreibung" } }
      ]
    },
    {
      "id": "lxc_rollback_snapshot",
      "title": { "en": "Roll back to snapshot", "de": "Auf Snapshot zurücksetzen" },
      "titleFormatted": { "en": "Roll back to [[snapshot]]", "de": "Zurücksetzen auf [[snapshot]]" },
      "hint": { "en": "Discards all changes made since the snapshot was taken.", "de": "Verwirft alle Änderungen seit dem Snapshot." },
      "args": [
        { "name": "snapshot", "type": "autocomplete", "placeholder": { "en": "select snapshot", "de": "Snapshot wählen" } }
      ]
    },
    {
      "id": "lxc_backup",
      "title": { "en": "Create backup", "de": "Backup erstellen" },
      "titleFormatted": {
        "en": "Back up to [[storage]] in [[mode]] mode",
        "de": "Backup auf [[storage]] im Modus [[mode]]"
      },
      "args": [
        { "name": "storage", "type": "autocomplete", "placeholder": { "en": "backup storage", "de": "Backup-Storage" } },
        {
          "name": "mode",
          "type": "dropdown",
          "values": [
            { "id": "snapshot", "label": { "en": "Snapshot", "de": "Snapshot" } },
            { "id": "suspend", "label": { "en": "Suspend", "de": "Anhalten" } },
            { "id": "stop", "label": { "en": "Stop", "de": "Stoppen" } }
          ]
        }
      ]
    },
    {
      "id": "lxc_move_volume",
      "title": { "en": "Move volume to storage", "de": "Volume auf Storage verschieben" },
      "titleFormatted": {
        "en": "Move volume [[volume]] to [[storage]], delete source [[delete_source]]",
        "de": "Volume [[volume]] auf [[storage]] verschieben, Quelle löschen [[delete_source]]"
      },
      "hint": {
        "en": "The container must be stopped to move a volume.",
        "de": "Der Container muss zum Verschieben eines Volumes gestoppt sein."
      },
      "args": [
        { "name": "volume", "type": "autocomplete", "placeholder": { "en": "select volume", "de": "Volume wählen" } },
        { "name": "storage", "type": "autocomplete", "placeholder": { "en": "target storage", "de": "Ziel-Storage" } },
        { "name": "delete_source", "type": "checkbox", "required": false, "title": { "en": "Delete source", "de": "Quelle löschen" } }
      ]
    }
  ]
}
