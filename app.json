          "de": "Fortsetzen"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
      },
      {
        "id": "lxc_create_snapshot",
        "title": {
          "en": "Create snapshot",
          "de": "Snapshot erstellen"
        },
        "titleFormatted": {
          "en": "Create snapshot [[name]] with description [[description]]",
          "de": "Snapshot [[name]] mit Beschreibung [[description]] erstellen"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          },
          {
            "name": "name",
            "type": "text",
            "placeholder": {
              "en": "snapshot name",
              "de": "Snapshot-Name"
            }
          },
          {
            "name": "description",
            "type": "text",
            "required": false,
            "placeholder": {
              "en": "description (optional)",
              "de": "Beschreibung (optional)"
            }
          }
        ]
      },
      {
        "id": "lxc_rollback_snapshot",
        "title": {
          "en": "Roll back to snapshot",
          "de": "Auf Snapshot zurücksetzen"
        },
        "titleFormatted": {
          "en": "Roll back to [[snapshot]]",
          "de": "Zurücksetzen auf [[snapshot]]"
