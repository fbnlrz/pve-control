        "id": "lxc_start",
        "title": {
          "en": "Start",
          "de": "Starten"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
      },
      {
        "id": "lxc_shutdown",
        "title": {
          "en": "Shut down (graceful)",
          "de": "Herunterfahren (regulär)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
      },
      {
        "id": "lxc_stop",
        "title": {
          "en": "Stop (force)",
          "de": "Stoppen (hart)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
