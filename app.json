          "en": "VM stopped",
          "de": "VM gestoppt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=qemu"
          }
        ]
      },
      {
        "id": "qemu_status_changed",
        "title": {
          "en": "Status changed",
          "de": "Status geändert"
        },
        "tokens": [
          {
            "name": "status",
            "type": "string",
            "title": {
              "en": "Status",
              "de": "Status"
            },
