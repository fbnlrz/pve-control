        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=cluster"
          }
        ]
      },
      {
        "id": "lxc_is_running",
        "title": {
          "en": "Is running",
          "de": "Läuft"
        },
        "titleFormatted": {
          "en": "Container !{{is|isn't}} running",
          "de": "Container !{{läuft|läuft nicht}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
      },
      {
        "id": "qemu_is_running",
        "title": {
          "en": "Is running",
          "de": "Läuft"
        },
