  "flow": {
    "triggers": [
      {
        "id": "quorum_lost",
        "title": {
          "en": "Quorum lost",
          "de": "Quorum verloren"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=cluster"
          }
        ]
      },
      {
        "id": "quorum_restored",
        "title": {
          "en": "Quorum restored",
          "de": "Quorum wiederhergestellt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=cluster"
          }
        ]
      },
      {
        "id": "lxc_started",
        "title": {
          "en": "Container started",
          "de": "Container gestartet"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=lxc"
          }
        ]
      },
      {
